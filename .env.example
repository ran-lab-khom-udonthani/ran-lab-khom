# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง (อย่า commit .env)
# cp .env.example .env

# ฐานข้อมูล
# - ตอนพัฒนาในเครื่อง (SQLite):
DATABASE_URL="file:./dev.db"
# - ตอนขึ้นออนไลน์ (Vercel) ใช้ Postgres เช่น Neon/Supabase:
# DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# กุญแจเซ็นเซสชันล็อกอินพนักงาน — สุ่มใหม่: openssl rand -hex 32
AUTH_SECRET="เปลี่ยนเป็นค่าสุ่ม-อย่าใช้ค่านี้จริง"

# รหัสผ่านพนักงานร้าน
STAFF_PASSWORD="เปลี่ยนรหัสนี้"

# ชื่อร้านที่แสดงบนแอป
NEXT_PUBLIC_SHOP_NAME="ร้านลับคมอุดรธานี"
